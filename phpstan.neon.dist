includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    ignoreErrors:
        - message: '#Trait .+ is used zero times and is not analysed\.#'
          paths:
              - src/Traits/
        - message: "#Called 'env' outside of the config directory#"
          paths:
              - config/
